{
  "$schema": "../schema/1.0/contract.json",
  "kind": "contract",
  "id": "banking",
  "version": "1.0",
  "title": "Consumer Banking",
  "description": "Abstract interface for consumer banking actions. Shared across every org and surface that exposes a banking category; concrete behavior lives in per-(org x surface) bindings.",
  "required": ["checkBalance"],
  "methods": {
    "checkBalance": {
      "summary": "Read the available balance of an account.",
      "params": {
        "type": "object",
        "required": ["account"],
        "properties": {
          "account": { "type": "string", "description": "Account identifier or nickname." }
        }
      },
      "returns": {
        "type": "object",
        "required": ["balance", "currency"],
        "properties": {
          "balance": { "type": "number", "description": "Available balance." },
          "currency": { "type": "string", "description": "ISO 4217 currency code." },
          "asOf": { "type": "string", "format": "date-time", "description": "Timestamp the balance was read." }
        }
      },
      "errors": [
        { "code": "ACCOUNT_NOT_FOUND", "message": "No account matched the supplied identifier." }
      ]
    },
    "transfer": {
      "summary": "Move funds between two accounts held by the user.",
      "params": {
        "type": "object",
        "required": ["from", "to", "amount"],
        "properties": {
          "from": { "type": "string", "description": "Source account identifier." },
          "to": { "type": "string", "description": "Destination account identifier." },
          "amount": { "type": "number", "minimum": 0, "description": "Amount to transfer." }
        }
      },
      "returns": {
        "type": "object",
        "required": ["confirmationId", "status"],
        "properties": {
          "confirmationId": { "type": "string", "description": "Provider confirmation reference." },
          "status": { "type": "string", "enum": ["posted", "pending"], "description": "Settlement state at time of response." }
        }
      },
      "errors": [
        { "code": "ACCOUNT_NOT_FOUND", "message": "Source or destination account not found." },
        { "code": "INSUFFICIENT_FUNDS", "message": "The source account lacks sufficient available funds." },
        { "code": "LIMIT_EXCEEDED", "message": "The amount exceeds a transfer limit." }
      ]
    },
    "payBill": {
      "summary": "Pay a registered payee.",
      "params": {
        "type": "object",
        "required": ["payee", "amount"],
        "properties": {
          "payee": { "type": "string", "description": "Registered payee name or identifier." },
          "amount": { "type": "number", "minimum": 0, "description": "Payment amount." }
        }
      },
      "returns": {
        "type": "object",
        "required": ["confirmationId", "status"],
        "properties": {
          "confirmationId": { "type": "string" },
          "status": { "type": "string", "enum": ["posted", "pending", "scheduled"] }
        }
      },
      "errors": [
        { "code": "PAYEE_NOT_FOUND", "message": "No registered payee matched." },
        { "code": "INSUFFICIENT_FUNDS", "message": "Insufficient available funds to pay the bill." }
      ]
    },
    "wireTransfer": {
      "summary": "Send a wire transfer to an external account.",
      "params": {
        "type": "object",
        "required": ["to", "routing", "amount"],
        "properties": {
          "to": { "type": "string", "description": "Beneficiary account number." },
          "routing": { "type": "string", "description": "Routing / ABA number." },
          "amount": { "type": "number", "minimum": 0 }
        }
      },
      "returns": {
        "type": "object",
        "required": ["confirmationId", "status"],
        "properties": {
          "confirmationId": { "type": "string" },
          "status": { "type": "string", "enum": ["posted", "pending"] }
        }
      },
      "errors": [
        { "code": "INVALID_ROUTING", "message": "The routing number failed validation." },
        { "code": "INSUFFICIENT_FUNDS", "message": "Insufficient available funds for the wire." },
        { "code": "LIMIT_EXCEEDED", "message": "The amount exceeds a wire limit." }
      ]
    },
    "orderChecks": {
      "summary": "Order a checkbook for an account.",
      "params": {
        "type": "object",
        "required": ["account", "quantity"],
        "properties": {
          "account": { "type": "string" },
          "quantity": { "type": "integer", "minimum": 1 }
        }
      },
      "returns": {
        "type": "object",
        "required": ["orderId"],
        "properties": {
          "orderId": { "type": "string" },
          "estimatedDelivery": { "type": "string", "format": "date", "description": "Estimated delivery date." }
        }
      },
      "errors": [
        { "code": "ACCOUNT_NOT_FOUND", "message": "No account matched the supplied identifier." }
      ]
    }
  }
}
